{
  "protocol": "ftp",
  "port": 21,
  "secure": true,
  "secureOptions": {
    "rejectUnauthorized": false
  },
  "context": "dist",
  "useTempFile": true,
  "openSsh": false,
  "remotePath": "/ERROR_PLEASE_SET_PROFILE",
  "uploadOnSave": false,
  "ignore": [
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/*.psd",
    "**/*.ai",
    "**/wp-config.php"
  ],
  "profiles": {
    "staging": {
      "name": "Staging",
      "host": "",
      "username": "",
      "password": "",
      "remotePath": "",
      "uploadOnSave": true,
      "watcher": {
        "files": "dist/**/*",
        "autoUpload": true,
        "autoDelete": true
      }
    },
    "production": {
      "name": "Production",
      "host": "",
      "username": "",
      "password": "",
      "remotePath": "",
      "uploadOnSave": false,
      "watcher": {
        "autoUpload": false,
        "autoDelete": false
      }
    }
  }
}