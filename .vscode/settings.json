{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/htdocs/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/htdocs": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "files.associations": {
    "*.ejs": "php"
  },
  "editor.formatOnSave": false
}