<?php
/*
Plugin Name: Demo Styles
Description: 雛形テーマのデモテンプレートに最低限のスタイルを当てる開発用プラグイン。実案件では無効化または削除する。
Version: 1.0.0
*/

if ( ! defined( 'ABSPATH' ) ) exit;

add_action( 'wp_enqueue_scripts', function () {
  wp_enqueue_style(
    'demo_styles_css',
    plugins_url( 'css/demo.css', __FILE__ ),
    array(),
    filemtime( plugin_dir_path( __FILE__ ) . 'css/demo.css' )
  );
}, 110 ); // テーマのenqueue（priority 100）より後に読み込む
